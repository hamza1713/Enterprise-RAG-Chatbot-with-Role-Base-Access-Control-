# FinSight — Environment Variables Template
# Copy this file to `.env` and fill in your API keys.

# ── Required ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ── Optional AI integrations ───────────────────────────────────────────────────
COHERE_API_KEY=                  # Cohere reranker (skip if unused)
LANGCHAIN_API_KEY=               # LangSmith tracing (skip if unused)

# ── Database (defaults work out of the box) ────────────────────────────────────
DB_NAME=roles_docs.db
DUCKDB_NAME=structured_queries.duckdb

# ── Security ───────────────────────────────────────────────────────────────────
# JWT_SECRET=             # Auto-generated if blank; set for multi-server deploys

# ── Default user passwords (change before production!) ────────────────────────
ADMIN_PASSWORD=admin123
MARKETING_PASSWORD=marketing123
HR_PASSWORD=hr123
FINANCE_PASSWORD=finance123
ENGINEERING_PASSWORD=engineering123
HAMZA_PASSWORD=marketing123
